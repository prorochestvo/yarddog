# yarddog — LOCAL development env example.
#
# Copy to ./.env (git-ignored) and run from the repo:
#   cp local.env.example .env
#   make run          # collector (soft mode)
#   make run-daemon   # query daemon
# Both read ./.env when /opt/yarddog/.env is absent.
#
# Every key is namespaced with the YARDDOG_ prefix (a real env var still wins
# over the file). Tuned for a quick local smoke test, NOT a deployment. For a
# real install use yarddog.env.example -> /opt/yarddog/.env (chmod 600), which
# documents every variable and its default.

# --- shared ---
# local SQLite path, so nothing has to exist under /var/lib/yarddog; both
# binaries share this one file (the collector writes it, the daemon reads it).
YARDDOG_DB_PATH=./yarddog.db

# --- collector (yarddog) ---
YARDDOG_LABEL=local
# a structurally valid bot DSN is required even locally — the Telegram client
# parses it at startup. Use your own test bot: tbot://<chat_id>:@<bot_token>/
YARDDOG_TELEGRAMBOT_DSN="tbot://<chat_id>:@<bot_token>/"
# monitor-only: check/record/notify but never touch the router, so the router
# credentials below can stay dummy.
YARDDOG_REBOOT_ENABLED=false
YARDDOG_ROUTER_USER=admin
YARDDOG_ROUTER_PASS=dummy
# NOTE: the collector opens a flock named yarddog.lock in the DB's directory
# (here ./yarddog.lock, beside YARDDOG_DB_PATH above). It is created on demand
# in a dir you already own, so local runs need no /var/run provisioning.

# --- daemon (yarddogd) ---
# any non-empty secret; send it as: Authorization: Bearer <token>
YARDDOG_DAEMON_TOKEN=local-dev-token
# loopback default (127.0.0.1:8420) is fine locally; set a LAN ip:port to expose.
#YARDDOG_DAEMON_ADDR=127.0.0.1:8420
